{
  "name": "@thinktank/cli",
  "version": "0.0.0",
  "private": true,
  "description": "thinktank CLI: serve (stdio/http), setup (wire MCP into Cursor/Claude/Codex), and ingest.",
  "type": "module",
  "bin": {
    "thinktank": "./dist/cli.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "node --no-warnings=ExperimentalWarning --import tsx src/cli.ts"
  },
  "dependencies": {
    "@thinktank/core": "workspace:*",
    "@thinktank/ingest": "workspace:*",
    "@thinktank/mcp-server": "workspace:*",
    "adm-zip": "^0.5.16",
    "express": "^5.1.0",
    "multer": "^2.0.1"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
