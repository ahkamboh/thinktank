{
  "name": "@thinktank/core",
  "version": "0.0.0",
  "private": true,
  "description": "thinktank core: local-first storage (node:sqlite + sqlite-vec + FTS5), local embeddings, and the merge/retrieval engine.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm run test:roundtrip && pnpm run test:merge && pnpm run test:extract && pnpm run test:redact && pnpm run test:crypto",
    "test:roundtrip": "node --no-warnings=ExperimentalWarning --import tsx test/roundtrip.ts",
    "test:merge": "node --no-warnings=ExperimentalWarning --import tsx test/merge.ts",
    "test:extract": "node --no-warnings=ExperimentalWarning --import tsx test/extract.ts",
    "test:redact": "node --no-warnings=ExperimentalWarning --import tsx test/redact.ts",
    "test:crypto": "node --no-warnings=ExperimentalWarning --import tsx test/crypto.ts"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.3.0",
    "sqlite-vec": "^0.1.9"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
